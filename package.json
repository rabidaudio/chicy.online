{
  "name": "static-chic.online",
  "version": "0.1.0",
  "description": "Easy and cheap static site hosting on AWS",
  "keywords": [
    "static",
    "hosting",
    "cli"
  ],
  "homepage": "https://github.com/rabidaudio/static-chic.online#readme",
  "bugs": {
    "url": "https://github.com/rabidaudio/static-chic.online/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rabidaudio/static-chic.online.git"
  },
  "license": "MIT",
  "author": "Julien Dorothy, julien@rabidaudio.com",
  "type": "commonjs",
  "main": "dist/cli.js",
  "bin": {
    "statchic": "bin/cli"
  },
  "directories": {
    "test": "tests"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "serve:local": "node src/local_server.js",
    "build": "node esbuild.js all",
    "deploy": "dotenvx run -- serverless deploy",
    "publish": "run-s build deploy",
    "lint": "standard --fix",
    "test:run": "node tests/index.js",
    "test": "run-s build test:run",
    "audit": "npm audit --omit dev"
  },
  "dependencies": {
    "@aws-sdk/client-cloudfront": "^3.1011.0",
    "@aws-sdk/client-dynamodb": "^3.1011.0",
    "@aws-sdk/client-route-53": "^3.1011.0",
    "@aws-sdk/client-s3": "^3.1011.0",
    "@aws-sdk/client-sts": "^3.1011.0",
    "@aws-sdk/lib-dynamodb": "^3.1011.0",
    "@aws-sdk/lib-storage": "^3.1011.0",
    "@inquirer/prompts": "^8.3.0",
    "@koa/bodyparser": "^6.1.0",
    "@koa/router": "^15.3.1",
    "chalk": "^4.1.0",
    "cli-table3": "^0.6.5",
    "console-table-printer": "^2.15.0",
    "is-interactive": "^2.0.0",
    "koa": "^3.1.2",
    "lowdb": "^7.0.1",
    "mime-types": "^3.0.2",
    "moment": "^2.30.1",
    "namor": "^3.0.3",
    "ora": "^9.3.0",
    "pretty-bytes": "^7.1.0",
    "serverless-http": "^3.2.0",
    "simple-git": "^3.32.3",
    "tar": "^7.5.10",
    "winston": "^3.19.0",
    "xdg-portable": "^10.6.0",
    "yargs": "^18.0.0"
  },
  "devDependencies": {
    "@dotenvx/dotenvx": "^1.54.1",
    "chai": "^6.2.2",
    "esbuild": "^0.27.4",
    "fetch-vcr": "^3.2.0",
    "npm-run-all": "^4.1.5",
    "standard": "^17.1.2"
  },
  "engines": {
    "node": "24"
  },
  "standard": {
    "ignore": [
      "edge.handler.js"
    ]
  }
}
